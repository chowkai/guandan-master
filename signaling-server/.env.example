# 信令服务器环境变量配置
# 复制此文件为 .env 并填写实际值

# 服务器端口
PORT=3000

# WebSocket 端口（如与 HTTP 不同）
WS_PORT=3001

# 运行环境 (development | production)
NODE_ENV=production

# 日志级别 (error | warn | info | debug)
LOG_LEVEL=info

# 允许的来源域（CORS，多个用逗号分隔）
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# JWT 密钥（用于认证，可选）
# JWT_SECRET=your-secret-key-here

# 最大连接数
MAX_CONNECTIONS=100

# 心跳间隔（毫秒）
HEARTBEAT_INTERVAL=30000
