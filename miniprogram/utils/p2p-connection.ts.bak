/**
 * P2PConnection - WebRTC 连接封装
 * 负责创建和管理 RTCPeerConnection，处理 ICE candidate 交换
 */

// WebRTC 配置
const DEFAULT_RTC_CONFIG: RTCConfiguration = {
  iceServers: [
    {
      urls: [
        'stun:stun.l.google.com:19302',
        'stun:stun1.l.google.com:19302',
        'stun:stun2.l.google.com:19302',
        'stun:stun3.l.google.com:19302',
        'stun:stun4.l.google.com:19302'
      ]
    }
  ],
  iceTransportPolicy: 'all',
  bundlePolicy: 'balanced'
};

/**
 * P2P 连接状态枚举
 */
export enum P2PConnectionState {
  NEW = 'new',
  CONNECTING = 'connecting',
  CONNECTED = 'connected',
  DISCONNECTED = 'disconnected',
  FAILED = 'failed',
  CLOSED = 'closed'
}

/**
 * P2PConnection 类
 * 封装 WebRTC PeerConnection 的核心功能
 */
export class P2PConnection {
  private pc: RTCPeerConnection | null = null;
  private iceCandidates: RTCIceCandidate[] = [];
  private onIceCandidateCallback: ((candidate: RTCIceCandidate) => void) | null = null;
  private onConnectionStateChangeCallback: ((state: string) => void) | null = null;
  private state: P2PConnectionState = P2PConnectionState.NEW;

  /**
   * 构造函数
   * @param config RTC 配置，可选，默认使用公共 STUN 服务器
   */
  constructor(config: RTCConfiguration = DEFAULT_RTC_CONFIG) {
    this.initialize(config);
  }

  /**
   * 初始化 PeerConnection
   */
  private initialize(config: RTCConfiguration): void {
    try {
      // 微信小程序环境使用 wx.createRTCPeerConnection
      // @ts-ignore - 微信小程序 API
      if (typeof wx !== 'undefined' && wx.createRTCPeerConnection) {
        // @ts-ignore
        this.pc = wx.createRTCPeerConnection(config);
      } else {
        // 标准浏览器环境
        const RTCPeerConnectionImpl = window.RTCPeerConnection || 
          // @ts-ignore
          window.webkitRTCPeerConnection || 
          // @ts-ignore
          window.mozRTCPeerConnection;
        
        if (RTCPeerConnectionImpl) {
          this.pc = new RTCPeerConnectionImpl(config);
        } else {
          throw new Error('WebRTC not supported in this environment');
        }
      }

      this.setupEventListeners();
    } catch (error) {
      console.error('[P2PConnection] Failed to initialize:', error);
      throw error;
    }
  }

  /**
   * 设置事件监听器
   */
  private setupEventListeners(): void {
    if (!this.pc) return;

    // ICE candidate 事件
    this.pc.onicecandidate = (event) => {
      if (event.candidate) {
        this.iceCandidates.push(event.candidate);
        if (this.onIceCandidateCallback) {
          this.onIceCandidateCallback(event.candidate);
        }
      }
    };

    // 连接状态变化事件
    this.pc.onconnectionstatechange = () => {
      if (!this.pc) return;
      
      this.state = this.pc.connectionState as P2PConnectionState;
      console.log('[P2PConnection] Connection state changed:', this.state);
      
      if (this.onConnectionStateChangeCallback) {
        this.onConnectionStateChangeCallback(this.state);
      }

      // 处理连接失败
      if (this.state === P2PConnectionState.FAILED) {
        console.error('[P2PConnection] Connection failed');
      }
    };

    // ICE 连接状态变化
    this.pc.oniceconnectionstatechange = () => {
      if (!this.pc) return;
      console.log('[P2PConnection] ICE state:', this.pc.iceConnectionState);
    };

    // 数据通道事件（由远程 peer 创建）
    this.pc.ondatachannel = (event) => {
      console.log('[P2PConnection] Received data channel:', event.channel.label);
    };
  }

  /**
   * 创建 Offer
   * @returns Promise<RTCSessionDescription>
   */
  async createOffer(): Promise<RTCSessionDescriptionInit> {
    if (!this.pc) {
      throw new Error('[P2PConnection] PeerConnection not initialized');
    }

    try {
      const offer = await this.pc.createOffer({
        offerToReceiveData: true
      });
      
      await this.pc.setLocalDescription(offer);
      
      // 等待 ICE candidate 收集完成
      await this.waitForIceGathering();
      
      return this.pc.localDescription || offer;
    } catch (error) {
      console.error('[P2PConnection] Failed to create offer:', error);
      throw error;
    }
  }

  /**
   * 创建 Answer
   * @param offer 远程 Offer
   * @returns Promise<RTCSessionDescription>
   */
  async createAnswer(offer: RTCSessionDescriptionInit): Promise<RTCSessionDescriptionInit> {
    if (!this.pc) {
      throw new Error('[P2PConnection] PeerConnection not initialized');
    }

    try {
      await this.pc.setRemoteDescription(offer);
      
      const answer = await this.pc.createAnswer();
      await this.pc.setLocalDescription(answer);
      
      // 等待 ICE candidate 收集完成
      await this.waitForIceGathering();
      
      return this.pc.localDescription || answer;
    } catch (error) {
      console.error('[P2PConnection] Failed to create answer:', error);
      throw error;
    }
  }

  /**
   * 等待 ICE candidate 收集完成
   */
  private waitForIceGathering(): Promise<void> {
    return new Promise((resolve) => {
      if (!this.pc) {
        resolve();
        return;
      }

      if (this.pc.iceGatheringState === 'complete') {
        resolve();
        return;
      }

      const checkState = () => {
        if (this.pc && this.pc.iceGatheringState === 'complete') {
          this.pc.removeEventListener('icegatheringstatechange', checkState);
          resolve();
        }
      };

      this.pc.addEventListener('icegatheringstatechange', checkState);
      
      // 超时保护（5 秒）
      setTimeout(() => {
        if (this.pc) {
          this.pc.removeEventListener('icegatheringstatechange', checkState);
        }
        resolve();
      }, 5000);
    });
  }

  /**
   * 设置远程描述
   * @param desc 远程会话描述
   */
  async setRemoteDescription(desc: RTCSessionDescriptionInit): Promise<void> {
    if (!this.pc) {
      throw new Error('[P2PConnection] PeerConnection not initialized');
    }

    try {
      await this.pc.setRemoteDescription(desc);
      console.log('[P2PConnection] Remote description set successfully');
    } catch (error) {
      console.error('[P2PConnection] Failed to set remote description:', error);
      throw error;
    }
  }
  }

  /**
   * 添加 ICE candidate
   * @param candidate ICE candidate
   */
  async addIceCandidate(candidate: RTCIceCandidateInit): Promise<void> {
    if (!this.pc) {
      throw new Error('[P2PConnection] PeerConnection not initialized');
    }

    try {
      await this.pc.addIceCandidate(candidate);
      console.log('[P2PConnection] ICE candidate added');
    } catch (error) {
      console.error('[P2PConnection] Failed to add ICE candidate:', error);
      // ICE candidate 添加失败通常可以忽略，继续尝试其他 candidate
    }
  }

  /**
   * 添加已收集的 ICE candidates
   * @param candidates ICE candidate 数组
   */
  async addIceCandidates(candidates: RTCIceCandidateInit[]): Promise<void> {
    for (const candidate of candidates) {
      await this.addIceCandidate(candidate);
    }
  }

  /**
   * 设置 ICE candidate 回调
   * @param callback 回调函数
   */
  onIceCandidate(callback: (candidate: RTCIceCandidate) => void): void {
    this.onIceCandidateCallback = callback;
  }

  /**
   * 设置连接状态变化回调
   * @param callback 回调函数
   */
  onConnectionStateChange(callback: (state: string) => void): void {
    this.onConnectionStateChangeCallback = callback;
  }

  /**
   * 获取当前连接状态
   */
  getState(): P2PConnectionState {
    return this.state;
  }

  /**
   * 检查连接是否已建立
   */
  isConnected(): boolean {
    return this.state === P2PConnectionState.CONNECTED;
  }

  /**
   * 创建数据通道
   * @param label 通道标签
   * @param options 通道选项
   * @returns RTCDataChannel
   */
  createDataChannel(label: string, options?: RTCDataChannelInit): RTCDataChannel {
    if (!this.pc) {
      throw new Error('[P2PConnection] PeerConnection not initialized');
    }

    const channel = this.pc.createDataChannel(label, options);
    this.setupDataChannel(channel);
    return channel;
  }

  /**
   * 设置数据通道事件监听
   */
  private setupDataChannel(channel: RTCDataChannel): void {
    channel.onopen = () => {
      console.log('[P2PConnection] Data channel opened:', channel.label);
    };

    channel.onclose = () => {
      console.log('[P2PConnection] Data channel closed:', channel.label);
    };

    channel.onerror = (error) => {
      console.error('[P2PConnection] Data channel error:', channel.label, error);
    };

    channel.onbufferedamountlow = () => {
      console.log('[P2PConnection] Data channel buffer cleared:', channel.label);
    };
  }

  /**
   * 关闭连接
   */
  close(): void {
    if (this.pc) {
      this.pc.close();
      this.pc = null;
      this.state = P2PConnectionState.CLOSED;
      console.log('[P2PConnection] Connection closed');
    }
  }

  /**
   * 获取 PeerConnection 实例（高级用法）
   */
  getPeerConnection(): RTCPeerConnection | null {
    return this.pc;
  }

  /**
   * 重置连接
   */
  reset(config?: RTCConfiguration): void {
    this.close();
    this.iceCandidates = [];
    this.state = P2PConnectionState.NEW;
    this.initialize(config || DEFAULT_RTC_CONFIG);
  }
}

export default P2PConnection;
