<!-- 主页面模板 -->
<view class="index-container">
  <!-- 背景装饰 -->
  <view class="bg-decoration"></view>
  
  <!-- 顶部用户信息 -->
  <view class="user-section">
    <view class="user-info" wx:if="{{hasLogin && userInfo}}">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view class="user-details">
        <text class="user-name">{{userInfo.nickName}}</text>
        <text class="user-welcome">欢迎回来</text>
      </view>
    </view>
    
    <view class="login-btn" wx:else bindtap="onLogin">
      <text>点击登录</text>
    </view>
  </view>
  
  <!-- 游戏标题 -->
  <view class="title-section">
    <text class="game-title">掼蛋</text>
    <text class="game-subtitle">经典扑克 欢乐对战</text>
  </view>
  
  <!-- 主菜单按钮 -->
  <view class="menu-section">
    <!-- 开始游戏 -->
    <view class="menu-item primary" bindtap="onStartGame">
      <view class="menu-icon">🎮</view>
      <text class="menu-text">开始游戏</text>
      <text class="menu-desc">单机模式</text>
    </view>
    
    <!-- P2P 联机 -->
    <view class="menu-item secondary" bindtap="onP2PConnect">
      <view class="menu-icon">🌐</view>
      <text class="menu-text">P2P 联机</text>
      <text class="menu-desc">好友对战</text>
    </view>
    
    <!-- 游戏规则 -->
    <view class="menu-item tertiary" bindtap="onViewRules">
      <view class="menu-icon">📖</view>
      <text class="menu-text">游戏规则</text>
      <text class="menu-desc">掼蛋规则简介</text>
    </view>
  </view>
  
  <!-- 底部设置 -->
  <view class="footer-section">
    <view class="settings-btn" bindtap="onOpenSettings">
      <text>⚙️ 设置</text>
    </view>
  </view>
</view>
