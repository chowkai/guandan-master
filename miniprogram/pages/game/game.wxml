<!-- 游戏页面模板 - 调试版本 -->
<view class="game-container" style="padding: 20rpx; min-height: 100vh; background: #1a472a;">
  <!-- 调试信息 -->
  <view style="background: rgba(0,0,0,0.8); color: #0f0; padding: 20rpx; margin-bottom: 20rpx; border-radius: 8rpx;">
    <text>手牌数：{{myCards.length}}</text>
    <text style="margin-left: 40rpx;">玩家数：{{players.length}}</text>
    <text style="margin-left: 40rpx;">状态：{{gameStatus}}</text>
  </view>
  
  <!-- 手牌列表 -->
  <view style="background: rgba(255,0,0,0.1); border: 2rpx solid red; padding: 20rpx; margin-bottom: 20rpx;">
    <text style="color: yellow; font-size: 28rpx; display: block; margin-bottom: 10rpx;">手牌详情 (共{{myCards.length}}张):</text>
    <view wx:for="{{myCards}}" wx:key="id" wx:for-item="card" 
          style="display: inline-block; background: white; padding: 10rpx; margin: 5rpx; border-radius: 8rpx;">
      <text>{{card.value}} {{card.suit}}</text>
    </view>
  </view>
  
  <!-- 玩家信息 -->
  <view style="background: rgba(0,255,0,0.1); border: 2rpx solid green; padding: 20rpx;">
    <text style="color: yellow; font-size: 28rpx; display: block; margin-bottom: 10rpx;">玩家信息:</text>
    <view wx:for="{{players}}" wx:key="playerId" wx:for-item="player" 
          style="background: white; padding: 10rpx; margin: 5rpx; border-radius: 8rpx;">
      <text>{{player.playerName}} - {{player.position}} - {{player.cardCount}}张</text>
    </view>
  </view>
</view>
