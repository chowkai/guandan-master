<!-- 游戏页面模板 -->
<view class="game-container">
  <!-- 信息提示区 - 修复 BUG-011 -->
  <view class="info-bar {{isFirstTurn ? 'highlight' : ''}}">
    <text class="info-text">{{infoText}}</text>
  </view>
  
  <!-- 牌桌背景 -->
  <view class="game-table"></view>
  
  <!-- 顶部玩家 (对家) -->
  <view class="player-top-area">
    <player
      wx:for="{{players}}"
      wx:if="{{item.position === 'top'}}"
      wx:key="playerId"
      player-id="{{item.playerId}}"
      player-name="{{item.playerName}}"
      avatar-url="{{item.avatarUrl}}"
      card-count="{{item.cardCount}}"
      is-self="{{item.isSelf}}"
      is-landlord="{{item.isLandlord}}"
      position="{{item.position}}"
    />
  </view>
  
  <!-- 左侧玩家 (上家) -->
  <view class="player-left-area">
    <player
      wx:for="{{players}}"
      wx:if="{{item.position === 'left'}}"
      wx:key="playerId"
      player-id="{{item.playerId}}"
      player-name="{{item.playerName}}"
      avatar-url="{{item.avatarUrl}}"
      card-count="{{item.cardCount}}"
      is-self="{{item.isSelf}}"
      is-landlord="{{item.isLandlord}}"
      position="{{item.position}}"
    />
  </view>
  
  <!-- 右侧玩家 (下家) -->
  <view class="player-right-area">
    <player
      wx:for="{{players}}"
      wx:if="{{item.position === 'right'}}"
      wx:key="playerId"
      player-id="{{item.playerId}}"
      player-name="{{item.playerName}}"
      avatar-url="{{item.avatarUrl}}"
      card-count="{{item.cardCount}}"
      is-self="{{item.isSelf}}"
      is-landlord="{{item.isLandlord}}"
      position="{{item.position}}"
    />
  </view>
  
  <!-- 中央出牌区 -->
  <view class="center-area">
    <play-area
      play-history="{{playHistory}}"
      current-play="{{currentPlay}}"
      is-expanded="{{false}}"
      bind:expandchange="onExpandChange"
    />
  </view>
  
  <!-- 底部手牌区 -->
  <view class="bottom-area">
    <!-- 手牌 -->
    <view class="hand-section">
      <hand-area
        cards="{{myCards}}"
        selected-cards="{{selectedCards}}"
        can-play="{{canPlay}}"
        bind:cardselect="onCardSelect"
      />
    </view>
    
    <!-- 操作按钮区 -->
    <view class="action-section">
      <view class="action-buttons">
        <button 
          class="action-btn pass-btn" 
          bindtap="onPass"
          disabled="{{!canPlay}}"
        >
          不出
        </button>
        
        <button 
          class="action-btn hint-btn" 
          bindtap="onHint"
        >
          提示
        </button>
        
        <button 
          class="action-btn play-btn" 
          bindtap="onPlayCards"
          disabled="{{!canPlay || selectedCards.length === 0}}"
        >
          出牌 ({{selectedCards.length}})
        </button>
      </view>
    </view>
    
    <!-- 底部玩家 (自己) -->
    <view class="player-bottom-area">
      <player
        wx:for="{{players}}"
        wx:if="{{item.position === 'bottom'}}"
        wx:key="playerId"
        player-id="{{item.playerId}}"
        player-name="{{item.playerName}}"
        avatar-url="{{item.avatarUrl}}"
        card-count="{{item.cardCount}}"
        is-self="{{item.isSelf}}"
        is-landlord="{{item.isLandlord}}"
        position="{{item.position}}"
      />
    </view>
  </view>
  
  <!-- 游戏状态提示 -->
  <view class="game-status-toast" wx:if="{{gameStatus === 'waiting'}}">
    <text>等待游戏开始...</text>
  </view>
</view>
