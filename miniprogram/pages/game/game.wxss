/**
 * 游戏页面样式
 */
.game-container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--deep-green) 0%, #0d2b1a 100%);
  position: relative;
  overflow: hidden;
  padding-top: 100rpx; /* 为信息提示区留空间 - 修复 BUG-011 */
}

/* 信息提示区 - 修复 BUG-011 */
.info-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: background 0.3s ease;
}

.info-bar.highlight {
  background: rgba(255, 215, 0, 0.8);
}

.info-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.info-bar.highlight .info-text {
  color: #000;
}

/* 牌桌背景 */
.game-table {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(ellipse at center, rgba(45, 90, 63, 0.3) 0%, transparent 70%),
    repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.02),
      rgba(255, 255, 255, 0.02) 10rpx,
      transparent 10rpx,
      transparent 20rpx
    );
  pointer-events: none;
}

/* 顶部玩家区域 */
.player-top-area {
  position: absolute;
  top: var(--spacing-lg);
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

/* 左侧玩家区域 */
.player-left-area {
  position: absolute;
  left: var(--spacing-md);
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

/* 右侧玩家区域 */
.player-right-area {
  position: absolute;
  right: var(--spacing-md);
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

/* 中央出牌区 */
.center-area {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  z-index: 5;
}

/* 底部区域 */
.bottom-area {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 20;
}

/* 手牌区域 */
.hand-section {
  padding: var(--spacing-md);
  background: linear-gradient(0deg, rgba(26, 71, 42, 0.9) 0%, rgba(26, 71, 42, 0.6) 100%);
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

/* 操作按钮区域 */
.action-section {
  padding: var(--spacing-md);
  background: rgba(0, 0, 0, 0.3);
}

.action-buttons {
  display: flex;
  justify-content: center;
  gap: var(--spacing-md);
}

.action-btn {
  min-width: 160rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-size-lg);
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
  box-shadow: var(--shadow-md);
}

.action-btn::after {
  border: none;
}

.pass-btn {
  background: rgba(255, 255, 255, 0.2);
  color: var(--white);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.pass-btn[disabled] {
  opacity: 0.5;
}

.hint-btn {
  background: rgba(255, 193, 7, 0.2);
  color: var(--yellow);
  border: 2rpx solid var(--yellow);
}

.play-btn {
  background: linear-gradient(135deg, var(--active-green) 0%, #2db84f 100%);
  color: var(--white);
  box-shadow: 0 4rpx 16rpx rgba(52, 199, 89, 0.4);
}

.play-btn[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

/* 底部玩家区域 */
.player-bottom-area {
  position: absolute;
  bottom: var(--spacing-md);
  right: var(--spacing-lg);
  transform: translateY(50%);
  z-index: 30;
}

/* 游戏状态提示 */
.game-status-toast {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: var(--spacing-lg) var(--spacing-xl);
  background: rgba(0, 0, 0, 0.8);
  border-radius: var(--radius-lg);
  z-index: 100;
}

.game-status-toast text {
  font-size: var(--font-size-lg);
  color: var(--white);
}

/* 出牌提示动画 */
@keyframes playHint {
  0%, 100% {
    box-shadow: 0 0 0 rgba(52, 199, 89, 0);
  }
  50% {
    box-shadow: 0 0 40rpx rgba(52, 199, 89, 0.6);
  }
}

.can-play-indicator {
  animation: playHint 1.5s infinite;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .center-area {
    width: 500rpx;
  }
  
  .action-buttons {
    gap: var(--spacing-sm);
  }
  
  .action-btn {
    min-width: 140rpx;
    height: 80rpx;
    font-size: var(--font-size-md);
  }
}

/* 卡牌选中提示 */
.selected-cards-count {
  position: absolute;
  top: -20rpx;
  right: var(--spacing-lg);
  padding: 8rpx 16rpx;
  background: var(--active-green);
  color: var(--white);
  border-radius: var(--radius-xl);
  font-size: var(--font-size-sm);
  font-weight: bold;
  box-shadow: var(--shadow-md);
}
