<!-- 游戏规则页面模板 -->
<scroll-view class="rules-container" scroll-y enhanced show-scrollbar="{{false}}">
  <!-- 标题 -->
  <view class="rules-header">
    <text class="header-title">掼蛋规则简介</text>
    <text class="header-subtitle">经典扑克 欢乐对战</text>
  </view>
  
  <!-- 游戏概述 -->
  <view class="rules-section">
    <view class="section-header">
      <text class="section-icon">📖</text>
      <text class="section-title">游戏概述</text>
    </view>
    <view class="section-content">
      <text class="content-text">
        掼蛋是一种起源于江苏淮安的扑克牌游戏，由"跑得快"和"八十分"演变而来。
        游戏采用两副扑克牌，共 4 名玩家，对家为一方进行配合，进行对抗。
      </text>
    </view>
  </view>
  
  <!-- 基本规则 -->
  <view class="rules-section">
    <view class="section-header">
      <text class="section-icon">🎯</text>
      <text class="section-title">基本规则</text>
    </view>
    <view class="section-content">
      <view class="rule-item">
        <text class="rule-number">1</text>
        <text class="rule-text">使用两副扑克牌（108 张），4 人游戏，对家为一方</text>
      </view>
      <view class="rule-item">
        <text class="rule-number">2</text>
        <text class="rule-text">从 2 开始打，依次打 3、4...到 A，先过 A 方获胜</text>
      </view>
      <view class="rule-item">
        <text class="rule-number">3</text>
        <text class="rule-text">每局先出完牌的一方为胜，根据名次决定进贡</text>
      </view>
      <view class="rule-item">
        <text class="rule-number">4</text>
        <text class="rule-text">级牌（当前打几，几就是级牌）可作百搭牌使用</text>
      </view>
    </view>
  </view>
  
  <!-- 牌型介绍 -->
  <view class="rules-section">
    <view class="section-header">
      <text class="section-icon">🃏</text>
      <text class="section-title">牌型介绍</text>
    </view>
    <view class="section-content">
      <view class="card-type-item">
        <text class="card-type-name">单牌</text>
        <text class="card-type-desc">任意一张牌</text>
      </view>
      <view class="card-type-item">
        <text class="card-type-name">对子</text>
        <text class="card-type-desc">两张点数相同的牌</text>
      </view>
      <view class="card-type-item">
        <text class="card-type-name">三张</text>
        <text class="card-type-desc">三张点数相同的牌</text>
      </view>
      <view class="card-type-item">
        <text class="card-type-name">三带二</text>
        <text class="card-type-desc">三张同点 + 一对</text>
      </view>
      <view class="card-type-item">
        <text class="card-type-name">顺子</text>
        <text class="card-type-desc">五张连续单牌（A 最大）</text>
      </view>
      <view class="card-type-item">
        <text class="card-type-name">连对</text>
        <text class="card-type-desc">三对及以上连续对子</text>
      </view>
      <view class="card-type-item">
        <text class="card-type-name">钢板</text>
        <text class="card-type-desc">两个连续三张</text>
      </view>
      <view class="card-type-item">
        <text class="card-type-name">炸弹</text>
        <text class="card-type-desc">四张及以上同点牌</text>
      </view>
      <view class="card-type-item">
        <text class="card-type-name">同花顺</text>
        <text class="card-type-desc">五张连续同花色牌</text>
      </view>
    </view>
  </view>
  
  <!-- 牌型大小 -->
  <view class="rules-section">
    <view class="section-header">
      <text class="section-icon">⚖️</text>
      <text class="section-title">牌型大小</text>
    </view>
    <view class="section-content">
      <view class="size-rule">
        <text class="size-label">单牌大小：</text>
        <text class="size-value">大王 > 小王 > 级牌 > A > K > Q > J > 10 > ... > 3 > 2</text>
      </view>
      <view class="size-rule">
        <text class="size-label">炸弹大小：</text>
        <text class="size-value">张数多的 > 张数少的；同张数比点数</text>
      </view>
      <view class="size-rule">
        <text class="size-label">特殊：</text>
        <text class="size-value">同花顺 > 炸弹（除天王炸）</text>
      </view>
    </view>
  </view>
  
  <!-- 进贡规则 -->
  <view class="rules-section">
    <view class="section-header">
      <text class="section-icon">🎁</text>
      <text class="section-title">进贡规则</text>
    </view>
    <view class="section-content">
      <view class="tribute-item">
        <text class="tribute-title">单贡</text>
        <text class="tribute-desc">末游向头游进贡最大牌</text>
      </view>
      <view class="tribute-item">
        <text class="tribute-title">双贡</text>
        <text class="tribute-desc">三游向头游、末游向二游分别进贡</text>
      </view>
      <view class="tribute-item">
        <text class="tribute-title">红心级牌</text>
        <text class="tribute-desc">红心级牌（百搭）不需要进贡</text>
      </view>
      <view class="tribute-item">
        <text class="tribute-title">还贡</text>
        <text class="tribute-desc">接受进贡者还贡一张 10 以下的牌</text>
      </view>
    </view>
  </view>
  
  <!-- 升级规则 -->
  <view class="rules-section">
    <view class="section-header">
      <text class="section-icon">📈</text>
      <text class="section-title">升级规则</text>
    </view>
    <view class="section-content">
      <view class="upgrade-item">
        <text class="upgrade-condition">头游 + 二游</text>
        <text class="upgrade-result">升 3 级</text>
      </view>
      <view class="upgrade-item">
        <text class="upgrade-condition">头游 + 三游</text>
        <text class="upgrade-result">升 2 级</text>
      </view>
      <view class="upgrade-item">
        <text class="upgrade-condition">头游 + 末游</text>
        <text class="upgrade-result">升 1 级</text>
      </view>
      <view class="upgrade-item">
        <text class="upgrade-condition">双下（头游 + 末游 vs 二游 + 三游）</text>
        <text class="upgrade-result">输方下次进双贡</text>
      </view>
    </view>
  </view>
  
  <!-- 特殊牌型 -->
  <view class="rules-section">
    <view class="section-header">
      <text class="section-icon">⭐</text>
      <text class="section-title">特殊说明</text>
    </view>
    <view class="section-content">
      <view class="special-item">
        <text class="special-text">🃏 <text class="highlight">级牌百搭</text>：级牌可代替任意牌（红心级牌必为百搭）</text>
      </view>
      <view class="special-item">
        <text class="special-text">👑 <text class="highlight">天王炸</text>：四大王可组成天王炸，最大牌型</text>
      </view>
      <view class="special-item">
        <text class="special-text">🔄 <text class="highlight">接风</text>：上家出完牌，下家获得出牌权</text>
      </view>
      <view class="special-item">
        <text class="special-text">💣 <text class="highlight">炸弹限制</text>：每局每方最多使用 3 个炸弹（不含天王炸）</text>
      </view>
    </view>
  </view>
  
  <!-- 底部提示 -->
  <view class="rules-footer">
    <text class="footer-text">祝您游戏愉快！🎮</text>
  </view>
  
  <!-- 占位，避免内容被底部遮挡 -->
  <view style="height: 100rpx;"></view>
</scroll-view>
