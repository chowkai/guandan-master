/**
 * 游戏规则页面样式
 */
.rules-container {
  height: 100vh;
  background: linear-gradient(180deg, var(--deep-green) 0%, var(--light-green) 100%);
}

/* 头部 */
.rules-header {
  padding: var(--spacing-xl) var(--spacing-lg);
  text-align: center;
  background: rgba(0, 0, 0, 0.2);
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--white);
  margin-bottom: var(--spacing-sm);
}

.header-subtitle {
  display: block;
  font-size: var(--font-size-md);
  color: rgba(255, 255, 255, 0.8);
}

/* 规则区域 */
.rules-section {
  margin: var(--spacing-lg);
  background: rgba(255, 255, 255, 0.95);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.section-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  background: linear-gradient(135deg, var(--active-green) 0%, #2db84f 100%);
}

.section-icon {
  font-size: var(--font-size-lg);
  margin-right: var(--spacing-sm);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--white);
}

.section-content {
  padding: var(--spacing-md) var(--spacing-lg);
}

.content-text {
  font-size: var(--font-size-md);
  color: var(--dark-gray);
  line-height: 1.8;
}

/* 规则项 */
.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--spacing-md);
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, var(--active-green) 0%, #2db84f 100%);
  color: var(--white);
  font-size: var(--font-size-sm);
  font-weight: bold;
  border-radius: 50%;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.rule-text {
  font-size: var(--font-size-md);
  color: var(--dark-gray);
  line-height: 1.6;
  padding-top: var(--spacing-xs);
}

/* 牌型项 */
.card-type-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-type-item:last-child {
  border-bottom: none;
}

.card-type-name {
  font-size: var(--font-size-md);
  font-weight: bold;
  color: var(--deep-green);
}

.card-type-desc {
  font-size: var(--font-size-sm);
  color: var(--gray);
}

/* 大小规则 */
.size-rule {
  margin-bottom: var(--spacing-md);
}

.size-rule:last-child {
  margin-bottom: 0;
}

.size-label {
  font-size: var(--font-size-md);
  font-weight: bold;
  color: var(--deep-green);
}

.size-value {
  font-size: var(--font-size-md);
  color: var(--dark-gray);
  line-height: 1.6;
}

/* 进贡项 */
.tribute-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.tribute-item:last-child {
  border-bottom: none;
}

.tribute-title {
  font-size: var(--font-size-md);
  font-weight: bold;
  color: var(--deep-green);
}

.tribute-desc {
  font-size: var(--font-size-sm);
  color: var(--gray);
  text-align: right;
  flex: 1;
  margin-left: var(--spacing-md);
}

/* 升级项 */
.upgrade-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.upgrade-item:last-child {
  border-bottom: none;
}

.upgrade-condition {
  font-size: var(--font-size-md);
  color: var(--dark-gray);
  flex: 1;
}

.upgrade-result {
  font-size: var(--font-size-md);
  font-weight: bold;
  color: var(--active-green);
}

/* 特殊项 */
.special-item {
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-sm);
  background: #f8f8f8;
  border-radius: var(--radius-md);
}

.special-item:last-child {
  margin-bottom: 0;
}

.special-text {
  font-size: var(--font-size-md);
  color: var(--dark-gray);
  line-height: 1.6;
}

.highlight {
  font-weight: bold;
  color: var(--deep-green);
}

/* 底部 */
.rules-footer {
  padding: var(--spacing-xl);
  text-align: center;
}

.footer-text {
  font-size: var(--font-size-lg);
  color: var(--white);
  opacity: 0.8;
}
