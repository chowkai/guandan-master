<!-- 设置页面模板 -->
<view class="settings-container">
  <!-- 设置项列表 -->
  <view class="settings-section">
    <view class="section-title">游戏设置</view>
    
    <!-- 音效开关 -->
    <view class="settings-item" bindtap="toggleSoundEffect">
      <view class="item-left">
        <text class="item-icon">🔊</text>
        <text class="item-label">音效</text>
      </view>
      <view class="item-right">
        <view class="switch {{soundEffect ? 'active' : ''}}" bindtap="toggleSoundEffect">
          <view class="switch-handle"></view>
        </view>
      </view>
    </view>
    
    <!-- 音乐开关 -->
    <view class="settings-item" bindtap="toggleBackgroundMusic">
      <view class="item-left">
        <text class="item-icon">🎵</text>
        <text class="item-label">背景音乐</text>
      </view>
      <view class="item-right">
        <view class="switch {{backgroundMusic ? 'active' : ''}}" bindtap="toggleBackgroundMusic">
          <view class="switch-handle"></view>
        </view>
      </view>
    </view>
    
    <!-- 震动反馈 -->
    <view class="settings-item" bindtap="toggleVibration">
      <view class="item-left">
        <text class="item-icon">📳</text>
        <text class="item-label">震动反馈</text>
      </view>
      <view class="item-right">
        <view class="switch {{vibration ? 'active' : ''}}" bindtap="toggleVibration">
          <view class="switch-handle"></view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 显示设置 -->
  <view class="settings-section">
    <view class="section-title">显示设置</view>
    
    <!-- 牌面大小 -->
    <view class="settings-item" bindtap="adjustCardSize">
      <view class="item-left">
        <text class="item-icon">🃏</text>
        <text class="item-label">牌面大小</text>
      </view>
      <view class="item-right">
        <text class="item-value">{{cardSizeLabel}}</text>
        <text class="item-arrow">›</text>
      </view>
    </view>
    
    <!-- 主题颜色 -->
    <view class="settings-item" bindtap="changeTheme">
      <view class="item-left">
        <text class="item-icon">🎨</text>
        <text class="item-label">主题颜色</text>
      </view>
      <view class="item-right">
        <text class="item-value">{{themeLabel}}</text>
        <text class="item-arrow">›</text>
      </view>
    </view>
  </view>
  
  <!-- 关于 -->
  <view class="settings-section">
    <view class="section-title">关于</view>
    
    <!-- 游戏规则 -->
    <view class="settings-item" bindtap="viewRules">
      <view class="item-left">
        <text class="item-icon">📖</text>
        <text class="item-label">游戏规则</text>
      </view>
      <view class="item-right">
        <text class="item-arrow">›</text>
      </view>
    </view>
    
    <!-- 版本号 -->
    <view class="settings-item">
      <view class="item-left">
        <text class="item-icon">ℹ️</text>
        <text class="item-label">版本</text>
      </view>
      <view class="item-right">
        <text class="item-value">{{version}}</text>
      </view>
    </view>
  </view>
  
  <!-- 底部按钮 -->
  <view class="footer-section">
    <button class="reset-btn" bindtap="resetSettings">恢复默认设置</button>
  </view>
</view>
