<!-- 玩家信息组件模板 -->
<view class="player-container {{getPositionClass()}} {{isSelf ? 'self' : ''}}">
  <!-- 头像区域 -->
  <view class="player-avatar-wrapper">
    <image 
      class="player-avatar" 
      src="{{avatarUrl ? avatarUrl : ''}}" 
      mode="aspectFill"
      wx:if="{{avatarUrl}}"
    />
    <!-- 无头像时显示占位符 -->
    <view class="player-avatar-placeholder" wx:else>
      <text>{{playerName ? playerName[0] : '玩'}}</text>
    </view>
    <!-- 地主标识 -->
    <view class="player-landlord-badge" wx:if="{{isLandlord}}">
      <text>地</text>
    </view>
  </view>
  
  <!-- 玩家名称 -->
  <view class="player-name">
    <text>{{playerName}}</text>
  </view>
  
  <!-- 剩余牌数角标 -->
  <view class="player-card-count" style="{{getCardCountStyle()}}">
    <text>{{getCardCountDisplay()}}</text>
  </view>
  
  <!-- 准备状态/出牌中指示器 -->
  <view class="player-status-indicator" wx:if="{{cardCount > 0}}">
    <view class="status-dot"></view>
  </view>
</view>
