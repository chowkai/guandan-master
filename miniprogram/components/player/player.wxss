/**
 * 玩家信息组件样式
 */
.player-container {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 底部玩家 (自己) */
.player-bottom {
  padding: var(--spacing-sm);
}

.player-bottom .player-avatar-wrapper {
  width: 100rpx;
  height: 100rpx;
}

.player-bottom .player-avatar {
  width: 100rpx;
  height: 100rpx;
}

/* 顶部玩家 (对手) */
.player-top {
  padding: var(--spacing-xs);
}

.player-top .player-avatar-wrapper {
  width: 80rpx;
  height: 80rpx;
}

.player-top .player-avatar {
  width: 80rpx;
  height: 80rpx;
}

/* 左侧玩家 */
.player-left {
  padding: var(--spacing-xs);
}

.player-left .player-avatar-wrapper {
  width: 70rpx;
  height: 70rpx;
}

.player-left .player-avatar {
  width: 70rpx;
  height: 70rpx;
}

/* 右侧玩家 */
.player-right {
  padding: var(--spacing-xs);
}

.player-right .player-avatar-wrapper {
  width: 70rpx;
  height: 70rpx;
}

.player-right .player-avatar {
  width: 70rpx;
  height: 70rpx;
}

/* 头像包装器 */
.player-avatar-wrapper {
  position: relative;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid var(--white);
  box-shadow: var(--shadow-md);
}

.player-avatar {
  border-radius: 50%;
  background-color: var(--light-gray);
}

/* 头像占位符 */
.player-avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--deep-green) 0%, var(--light-green) 100%);
  border: 4rpx solid var(--white);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: var(--shadow-md);
}

.player-avatar-placeholder text {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--white);
}

/* 地主标识 */
.player-landlord-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffb300 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 3rpx solid var(--white);
  box-shadow: var(--shadow-sm);
}

.player-landlord-badge text {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--dark-gray);
}

/* 玩家名称 */
.player-name {
  margin-top: var(--spacing-xs);
  padding: 4rpx 12rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: var(--radius-sm);
}

.player-name text {
  font-size: var(--font-size-sm);
  color: var(--white);
  font-weight: 500;
}

/* 剩余牌数角标 */
.player-card-count {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 3rpx solid var(--white);
  box-shadow: var(--shadow-md);
  z-index: 2;
}

.player-card-count text {
  font-size: var(--font-size-xs);
  font-weight: bold;
  color: var(--white);
}

/* 状态指示器 */
.player-status-indicator {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: var(--active-green);
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.2);
  }
}

/* 自己玩家的高亮效果 */
.player-container.self .player-avatar-wrapper {
  border-color: var(--active-green);
  box-shadow: 0 0 20rpx rgba(52, 199, 89, 0.5);
}
