/**
 * 出牌区组件样式
 */
.play-area-container {
  background: var(--white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  margin: var(--spacing-md);
}

/* 标题栏 */
.play-area-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md);
  background: linear-gradient(135deg, var(--deep-green) 0%, var(--light-green) 100%);
  cursor: pointer;
}

.play-area-title {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--white);
}

.play-area-round {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.8);
}

.expand-indicator {
  transition: transform 0.3s ease;
}

.expand-indicator text {
  color: var(--white);
  font-size: var(--font-size-sm);
}

.expand-indicator.expanded {
  transform: rotate(180deg);
}

/* 当前出牌区域 */
.current-play-area {
  padding: var(--spacing-md);
  background: rgba(52, 199, 89, 0.05);
  border-bottom: 2rpx solid var(--light-green);
}

.current-play-label {
  margin-bottom: var(--spacing-sm);
}

.current-play-label text {
  font-size: var(--font-size-sm);
  color: var(--active-green);
  font-weight: 500;
}

.current-play-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.current-play-card {
  flex-shrink: 0;
}

/* 历史记录区域 */
.play-history-area {
  padding: var(--spacing-md);
  max-height: 600rpx;
  overflow-y: auto;
}

.play-history-item {
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-sm);
  background: var(--light-gray);
  border-radius: var(--radius-md);
}

.play-history-item:last-child {
  margin-bottom: 0;
}

.play-history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-xs);
}

.play-history-round {
  font-size: var(--font-size-sm);
  font-weight: bold;
  color: var(--dark-gray);
}

.play-history-player {
  font-size: var(--font-size-sm);
  color: var(--gray);
}

.play-history-type {
  font-size: var(--font-size-xs);
  color: var(--active-green);
  padding: 4rpx 12rpx;
  background: rgba(52, 199, 89, 0.1);
  border-radius: var(--radius-sm);
}

.play-history-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.history-card {
  flex-shrink: 0;
  transform: scale(0.85);
}

/* 展开更多提示 */
.expand-more-hint {
  text-align: center;
  padding: var(--spacing-sm);
  margin-top: var(--spacing-sm);
}

.expand-more-hint text {
  font-size: var(--font-size-sm);
  color: var(--active-green);
}

/* 空状态 */
.play-area-empty {
  padding: var(--spacing-xl);
  text-align: center;
}

.play-area-empty .empty-text {
  font-size: var(--font-size-md);
  color: var(--gray);
}

/* 动画效果 */
@keyframes playCardIn {
  0% {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.current-play-card,
.history-card {
  animation: playCardIn 0.3s ease;
}

/* 折叠/展开过渡 */
.play-history-area {
  transition: max-height 0.3s ease;
}

.play-history-area.collapsed {
  max-height: 300rpx;
}
