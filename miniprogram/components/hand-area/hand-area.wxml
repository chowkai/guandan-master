<!-- 手牌区组件模板 -->
<view class="hand-area-container">
  <view class="hand-area-grid" style="{{getGridStyle()}}">
    <!-- 5 行网格布局 -->
    <view 
      class="hand-row" 
      wx:for="{{gridRows}}" 
      wx:key="index"
      style="{{getRowStyle()}}"
    >
      <!-- 每行的卡牌 -->
      <card
        wx:for="{{item}}"
        wx:for-item="cardItem"
        wx:key="id"
        class="hand-card"
        suit="{{cardItem.suit}}"
        value="{{cardItem.value}}"
        isSelected="{{isCardSelected(cardItem.suit, cardItem.value)}}"
        isPlayable="{{canPlay}}"
        cardWidth="{{cardWidth}}"
        cardHeight="{{cardHeight}}"
        bind:cardtap="onCardTap"
      />
    </view>
  </view>
  
  <!-- 空手牌提示 -->
  <view class="hand-area-empty" wx:if="{{cards.length === 0}}">
    <text>暂无手牌</text>
  </view>
</view>
