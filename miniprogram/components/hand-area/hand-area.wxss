/**
 * 手牌区组件样式
 * 5 行网格布局
 */
.hand-area-container {
  position: relative;
  padding: var(--spacing-md);
  background: rgba(26, 71, 42, 0.3);
  border-radius: var(--radius-lg);
  min-height: 600rpx;
  z-index: 100;
}

/* 网格容器 */
.hand-area-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  position: relative;
  z-index: 101;
}

/* 每一行 */
.hand-row {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  align-items: center;
  gap: 10px;
  min-height: 110rpx;
  position: relative;
  z-index: 102;
}

/* 手牌 - 关键：确保卡牌可见且可点击 */
.hand-card {
  flex-shrink: 0;
  transition: transform 0.2s ease;
  position: relative;
  z-index: 103;
  pointer-events: auto;
}

/* 强制卡牌容器可见 */
.hand-card .card-container {
  position: relative !important;
  z-index: 104 !important;
  pointer-events: auto !important;
}

/* 选中效果增强 */
.hand-card /deep/ .card-container.selected {
  z-index: 10;
}

/* 空手牌提示 */
.hand-area-empty {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.hand-area-empty text {
  font-size: var(--font-size-lg);
  color: var(--gray);
  opacity: 0.6;
}

/* 出牌动画 */
@keyframes cardPlayOut {
  0% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.1);
  }
  100% {
    opacity: 0;
    transform: scale(0.8) translateY(-100rpx);
  }
}

.hand-card.playing-out {
  animation: cardPlayOut 0.3s ease forwards;
}

/* 收牌动画 */
@keyframes cardDealIn {
  0% {
    opacity: 0;
    transform: scale(0.8) translateY(100rpx);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.hand-card.deal-in {
  animation: cardDealIn 0.3s ease forwards;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .hand-row {
    gap: 6px;
  }
  
  .hand-card {
    transform: scale(0.9);
  }
}

/* 提示可出牌 */
.hand-card.playable /deep/ .card-container {
  box-shadow: 0 0 16rpx rgba(52, 199, 89, 0.3);
}

/* 批量操作模式 */
.hand-area-container.batch-mode .hand-card {
  border: 2rpx solid var(--active-green);
}
