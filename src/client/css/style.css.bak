/* ========================================
   掼蛋大师 - 中国风样式表 v1.3
   Guandan Master - Chinese Style CSS
   ======================================== */

/* CSS 变量 - 中国风配色方案 */
:root {
    /* 主色调 - 中国红 */
    --china-red: #C41E3A;
    --china-red-dark: #8B0000;
    --china-red-light: #DC143C;
    
    /* 金色装饰 */
    --gold: #D4AF37;
    --gold-light: #FFD700;
    --gold-dark: #B8860B;
    
    /* 背景色 - 米白/宣纸色 */
    --bg-paper: #F5F0E6;
    --bg-paper-dark: #E8E0D0;
    --bg-paper-light: #FAF5F0;
    
    /* 文字色 */
    --text-dark: #1A1A1A;
    --text-medium: #4A4A4A;
    --text-light: #888888;
    
    /* 其他颜色 */
    --black: #1A1A1A;
    --white: #FFFFFF;
    --success: #28A745;
    --warning: #FFC107;
    --danger: #DC3545;
    
    /* 牌桌背景色 - 深绿色 */
    --table-green: #1a472a;
    --table-green-dark: #0f2e1d;
    --table-green-light: #2d5f3f;
    
    /* 尺寸变量 - 简洁设计 */
    --card-width: 120px;
    --card-height: 180px;
    --card-ratio: 1.5;
    
    /* 动画 */
    --transition-fast: 0.2s ease;
    --transition-normal: 0.3s ease;
    --transition-slow: 0.5s ease;
    
    /* 阴影 */
    --shadow-sm: 0 4px 8px rgba(0,0,0,0.3);
    --shadow-md: 0 6px 12px rgba(0,0,0,0.4);
    --shadow-lg: 0 10px 20px rgba(0,0,0,0.5);
    --shadow-xl: 0 15px 30px rgba(0,0,0,0.6);
}

/* 全局重置 */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    height: 100%;
    overflow: hidden;
    font-family: 'Noto Serif SC', 'Microsoft YaHei', 'SimHei', sans-serif;
    background: linear-gradient(135deg, var(--china-red-dark) 0%, var(--china-red) 50%, var(--china-red-light) 100%);
    color: var(--text-dark);
}

/* 游戏主容器 */
#game-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    max-width: 1400px;
    margin: 0 auto;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><rect fill="%23F5F0E6" width="100" height="100"/><path d="M0 0 L100 0 L100 100 L0 100 Z" fill="none" stroke="%23D4AF37" stroke-width="0.5" opacity="0.3"/></svg>');
    background-size: 100px 100px;
    position: relative;
}

/* 出牌提示条 */
.turn-indicator {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #c0392b, #e74c3c);
    color: white;
    padding: 15px 40px;
    border-radius: 25px;
    font-size: 20px;
    font-weight: bold;
    box-shadow: 0 6px 20px rgba(0,0,0,0.4);
    z-index: 2000;
    border: 2px solid var(--gold);
    text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
    animation: turnIndicatorPulse 2s ease-in-out infinite;
}

@keyframes turnIndicatorPulse {
    0%, 100% { 
        box-shadow: 0 6px 20px rgba(0,0,0,0.4);
        transform: translateX(-50%) scale(1);
    }
    50% { 
        box-shadow: 0 8px 30px rgba(231,76,60,0.6);
        transform: translateX(-50%) scale(1.02);
    }
}

/* 顶部信息栏 */
#game-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
    background: linear-gradient(to bottom, var(--china-red-dark), var(--china-red));
    border-bottom: 3px solid var(--gold);
    box-shadow: var(--shadow-md);
    z-index: 100;
}

.game-title {
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--gold);
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    letter-spacing: 4px;
}

.level-indicator {
    margin-left: 20px;
    color: var(--white);
    font-size: 1rem;
    background: rgba(0,0,0,0.2);
    padding: 5px 15px;
    border-radius: 20px;
    border: 1px solid var(--gold);
}

.header-right {
    display: flex;
    gap: 10px;
}

.icon-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--gold);
    background: rgba(255,255,255,0.1);
    color: var(--gold);
    font-size: 1.2rem;
    cursor: pointer;
    transition: var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
}

.icon-btn:hover {
    background: var(--gold);
    color: var(--china-red);
    transform: scale(1.1);
}

/* 游戏桌面 - 深绿色背景，固定尺寸 */
#game-table {
    flex: 1;
    display: grid;
    grid-template-areas:
        ". top ."
        "left center right"
        ". bottom .";
    grid-template-columns: 1fr 2fr 1fr;
    grid-template-rows: 1fr 1.5fr 1.2fr;
    gap: 10px;
    padding: 10px;
    position: relative;
    overflow: hidden;
    max-width: 1200px;
    max-height: 800px;
    margin: 0 auto;
    background: linear-gradient(135deg, var(--table-green) 0%, var(--table-green-dark) 50%, var(--table-green-light) 100%);
    border-radius: 20px;
    box-shadow: inset 0 0 50px rgba(0,0,0,0.5);
}

/* 玩家区域 - 优化布局 */
.player-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 8px;
    background: rgba(255,255,255,0.05);
    border-radius: 10px;
    border: 1px solid rgba(212,175,55,0.3);
    position: relative;
    min-width: 0;
    min-height: 0;
}

.player-top {
    grid-area: top;
    justify-content: flex-start;
    padding-top: 5px;
}

.player-left {
    grid-area: left;
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
}

.player-right {
    grid-area: right;
    flex-direction: row;
    justify-content: flex-start;
    align-items: center;
}

.player-bottom {
    grid-area: bottom;
    flex-direction: column;
    justify-content: flex-end;
}

/* 玩家信息 */
.player-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    margin-bottom: 10px;
}

.player-info-inline {
    display: flex;
    align-items: center;
    gap: 10px;
}

.player-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    border: 3px solid var(--white);
    box-shadow: var(--shadow-md);
}

.player-info-inline .player-avatar {
    width: 40px;
    height: 40px;
    font-size: 1.4rem;
}

.player-name {
    font-weight: bold;
    color: var(--gold);
    font-size: 1rem;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
}

.player-status {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    color: var(--white);
    font-size: 0.85rem;
}

.card-count {
    background: rgba(0,0,0,0.3);
    padding: 3px 10px;
    border-radius: 10px;
    border: 1px solid var(--gold);
}

.status-badge {
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 0.75rem;
    background: var(--gold);
    color: var(--china-red-dark);
    font-weight: bold;
}

.status-badge.active {
    background: var(--success);
    color: var(--white);
    animation: pulse 1s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
}

/* 出的牌区域 */
.played-cards {
    display: flex;
    gap: 5px;
    min-height: 60px;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
}

/* 中央区域 */
#center-area {
    grid-area: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
}

#last-hand-display {
    background: rgba(255,255,255,0.1);
    border: 2px solid var(--gold);
    border-radius: 15px;
    padding: 15px;
    min-width: 300px;
    min-height: 150px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
}

.last-hand-label {
    color: var(--gold);
    font-size: 0.9rem;
    margin-bottom: 10px;
    font-weight: bold;
}

.last-hand-cards {
    display: flex;
    gap: 5px;
    justify-content: center;
    flex-wrap: wrap;
}

.last-hand-info {
    color: var(--white);
    font-size: 0.85rem;
    margin-top: 10px;
    text-align: center;
}

.game-message {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(196,30,58,0.95);
    color: var(--gold);
    padding: 20px 40px;
    border-radius: 10px;
    border: 3px solid var(--gold);
    font-size: 1.5rem;
    font-weight: bold;
    text-align: center;
    box-shadow: var(--shadow-lg);
    z-index: 1000;
    display: none;
    animation: fadeInOut 2s ease;
}

@keyframes fadeInOut {
    0% { opacity: 0; transform: translate(-50%, -50%) scale(0.8); }
    20% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    80% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    100% { opacity: 0; transform: translate(-50%, -50%) scale(0.8); }
}

/* 我的手牌区域 - 两行布局 */
.hand-container {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 10px 0;
    margin-bottom: 10px;
}

.my-hand {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-content: center;
    gap: 5px;
    min-width: max-content;
    padding: 0 20px;
    max-width: 100%;
}

.my-hand .card {
    margin: 0;
    transition: var(--transition-fast);
    cursor: pointer;
    flex-shrink: 0;
}

.my-hand .card.selected {
    transform: translateY(-20px);
    box-shadow: var(--shadow-xl), 0 0 20px var(--gold);
    border-color: var(--gold-light);
    z-index: 10;
}

/* 玩家控制区 */
.player-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 10px 20px;
    background: rgba(0,0,0,0.2);
    border-radius: 10px;
    border: 1px solid rgba(212,175,55,0.3);
}

.action-buttons {
    display: flex;
    gap: 10px;
}

.action-btn {
    padding: 10px 25px;
    border: 2px solid var(--gold);
    border-radius: 25px;
    background: linear-gradient(to bottom, var(--bg-paper), var(--bg-paper-dark));
    color: var(--china-red-dark);
    font-weight: bold;
    font-size: 1rem;
    cursor: pointer;
    transition: var(--transition-fast);
    font-family: inherit;
}

.action-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.action-btn:active {
    transform: translateY(0);
}

.action-btn.btn-primary {
    background: linear-gradient(to bottom, var(--china-red-light), var(--china-red));
    color: var(--white);
}

.action-btn.btn-primary:hover {
    background: linear-gradient(to bottom, var(--china-red), var(--china-red-dark));
}

.action-btn.btn-secondary {
    background: linear-gradient(to bottom, var(--bg-paper-light), var(--bg-paper));
    color: var(--text-medium);
}

.action-btn.btn-hint {
    background: linear-gradient(to bottom, var(--gold-light), var(--gold));
    color: var(--china-red-dark);
}

.action-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
}

/* 底部状态栏 */
#game-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
    background: linear-gradient(to top, var(--china-red-dark), var(--china-red));
    border-top: 3px solid var(--gold);
    box-shadow: var(--shadow-md);
}

.footer-info {
    display: flex;
    gap: 20px;
    color: var(--white);
    font-size: 0.9rem;
}

.turn-indicator {
    background: var(--gold);
    color: var(--china-red-dark);
    padding: 3px 12px;
    border-radius: 10px;
    font-weight: bold;
}

.footer-controls {
    display: flex;
    gap: 10px;
}

.footer-btn {
    padding: 8px 20px;
    border: 2px solid var(--gold);
    border-radius: 20px;
    background: transparent;
    color: var(--gold);
    font-weight: bold;
    cursor: pointer;
    transition: var(--transition-fast);
}

.footer-btn:hover {
    background: var(--gold);
    color: var(--china-red-dark);
}

/* 卡牌样式 - 简洁设计 v1.3 (修正版) */
.card {
    width: var(--card-width);
    height: var(--card-height);
    background: var(--bg-paper);
    border-radius: 10px;
    border: 3px solid var(--white);
    box-shadow: var(--shadow-md), 0 0 0 1px var(--gold);
    position: relative;
    overflow: hidden;
    transition: var(--transition-fast);
    user-select: none;
}

.card:hover {
    box-shadow: var(--shadow-lg), 0 0 0 1px var(--gold-light);
}

/* 卡牌内容容器 */
.card-content {
    position: relative;
    width: 100%;
    height: 100%;
}

/* 左上角：竖排牌字 + 小花色 v1.3 */
.card-value-top {
    position: absolute;
    top: 8px;
    left: 8px;
    font-size: 20px;
    font-weight: bold;
    writing-mode: vertical-rl;  /* 竖排 */
    text-orientation: mixed;
    display: flex;
    flex-direction: column;
    gap: 2px;
    letter-spacing: 1px;
    line-height: 1;
}

/* 牌字竖排 */
.card-value-top .rank {
    font-weight: bold;
}

/* 花色跟随牌字竖排 */
.card-value-top .suit {
    font-size: 18px;
}

/* 中央：一个大花色图标 */
.card-suit-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 80px;
    line-height: 1;
}

/* 右下角：倒置牌字 + 花色 */
.card-corner-bottom {
    position: absolute;
    bottom: 5px;
    right: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    transform: rotate(180deg);
}

.card svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.card.card-back {
    background: linear-gradient(135deg, var(--china-red), var(--china-red-dark));
}

.card.card-back svg {
    width: 100%;
    height: 100%;
}

/* 大小王 - 竖排 JOKER + 王冠 */
.card-joker {
    background: linear-gradient(135deg, #fff5e6, #ffe6cc);
}

/* 大小王竖排 JOKER */
.card-joker .card-value-top {
    font-size: 18px;
    font-weight: bold;
    writing-mode: vertical-rl;  /* 竖排 */
    text-orientation: mixed;
    position: absolute;
    top: 10px;
    left: 8px;
    letter-spacing: 2px;
    color: #c0392b;  /* 红色 */
}

.card-joker .card-suit-center {
    font-size: 60px;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
}

.card-joker-small .card-value-top,
.card-joker-small .card-suit-center {
    color: #2E8B57;  /* 小王绿色 */
}

.card-joker-big .card-value-top,
.card-joker-big .card-suit-center {
    color: #C41E3A;  /* 大王红色 */
}

/* 模态框 */
.modal-panel {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.7);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    backdrop-filter: blur(5px);
}

.modal-panel.show {
    display: flex;
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.modal-content {
    background: var(--bg-paper);
    border-radius: 15px;
    border: 3px solid var(--gold);
    box-shadow: var(--shadow-lg);
    max-width: 500px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    animation: slideIn 0.3s ease;
}

@keyframes slideIn {
    from { transform: translateY(-50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 20px;
    background: linear-gradient(to right, var(--china-red), var(--china-red-dark));
    border-radius: 12px 12px 0 0;
    border-bottom: 2px solid var(--gold);
}

.modal-header h2 {
    color: var(--gold);
    font-size: 1.5rem;
}

.modal-close {
    width: 35px;
    height: 35px;
    border-radius: 50%;
    border: 2px solid var(--gold);
    background: transparent;
    color: var(--gold);
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-fast);
}

.modal-close:hover {
    background: var(--gold);
    color: var(--china-red);
}

.modal-body {
    padding: 20px;
}

.setting-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 0;
    border-bottom: 1px solid var(--bg-paper-dark);
}

.setting-item:last-child {
    border-bottom: none;
}

.setting-item label {
    font-weight: bold;
    color: var(--text-dark);
}

.setting-item select,
.setting-item input[type="range"] {
    padding: 8px 12px;
    border: 2px solid var(--gold);
    border-radius: 5px;
    background: var(--white);
    font-family: inherit;
}

.setting-item input[type="checkbox"] {
    width: 20px;
    height: 20px;
    accent-color: var(--china-red);
}

.help-content h3 {
    color: var(--china-red);
    margin: 15px 0 10px 0;
    font-size: 1.1rem;
}

.help-content h3:first-child {
    margin-top: 0;
}

.help-content p,
.help-content ul {
    color: var(--text-medium);
    line-height: 1.6;
    margin-bottom: 10px;
}

.help-content ul {
    padding-left: 20px;
}

.game-over-content {
    text-align: center;
    padding: 30px 20px;
}

#game-over-result {
    font-size: 1.2rem;
    color: var(--text-dark);
    margin-bottom: 30px;
    line-height: 1.8;
}

#btn-play-again {
    padding: 15px 40px;
    font-size: 1.2rem;
}

/* 响应式设计 - 平板 */
@media (max-width: 1024px) {
    :root {
        --card-width: 100px;
        --card-height: 150px;
    }
    
    .game-title {
        font-size: 1.5rem;
    }
    
    #game-table {
        grid-template-rows: 0.8fr 1.2fr 1fr;
    }
    
    .player-info-inline {
        flex-direction: column;
    }
    
    .action-buttons {
        flex-wrap: wrap;
        justify-content: center;
    }
    
    .turn-indicator {
        top: 15px;
        padding: 12px 30px;
        font-size: 18px;
    }
}

/* 响应式设计 - 手机 */
@media (max-width: 768px) {
    :root {
        --card-width: 70px;
        --card-height: 105px;
    }
    
    #game-header {
        padding: 8px 15px;
    }
    
    .game-title {
        font-size: 1.2rem;
        letter-spacing: 2px;
    }
    
    .level-indicator {
        font-size: 0.85rem;
        padding: 3px 10px;
    }
    
    #game-table {
        grid-template-areas:
            "top"
            "center"
            "bottom";
        grid-template-rows: auto 1fr auto;
        grid-template-columns: 1fr;
        gap: 5px;
        padding: 5px;
        overflow-y: auto;
    }
    
    .player-left,
    .player-right {
        display: none;
    }
    
    .player-area {
        padding: 5px;
    }
    
    #last-hand-display {
        min-width: 150px;
        min-height: 100px;
        padding: 8px;
    }
    
    .player-controls {
        flex-direction: column;
        gap: 8px;
    }
    
    .action-buttons {
        width: 100%;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .action-btn {
        padding: 6px 12px;
        font-size: 0.85rem;
    }
    
    .sort-buttons {
        order: -1;
        width: 100%;
        justify-content: center !important;
        margin-bottom: 5px !important;
    }
    
    #game-footer {
        flex-direction: column;
        gap: 10px;
        padding: 10px 15px;
    }
    
    .footer-info {
        flex-direction: column;
        align-items: center;
        gap: 5px;
    }
    
    .my-hand {
        gap: 3px;
        padding: 0 10px;
    }
    
    .turn-indicator {
        top: 10px;
        padding: 10px 20px;
        font-size: 16px;
        border-width: 1px;
    }
}

/* 响应式设计 - 小手机 */
@media (max-width: 480px) {
    :root {
        --card-width: 60px;
        --card-height: 90px;
    }
    
    .game-title {
        font-size: 1rem;
    }
    
    .icon-btn {
        width: 35px;
        height: 35px;
        font-size: 1rem;
    }
    
    .player-avatar {
        width: 35px;
        height: 35px;
        font-size: 1.3rem;
    }
    
    .player-info-inline .player-avatar {
        width: 30px;
        height: 30px;
        font-size: 1.1rem;
    }
    
    .turn-indicator {
        top: 8px;
        padding: 8px 15px;
        font-size: 14px;
    }
    
    .my-hand {
        gap: 2px;
        padding: 0 5px;
    }
    
    .action-btn {
        padding: 5px 10px;
        font-size: 0.8rem;
    }
}

/* ========================================
   游戏开始画面样式
   ======================================== */

#start-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--china-red-dark) 0%, var(--china-red) 50%, var(--china-red-light) 100%);
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 3000;
}

#start-screen.show {
    display: flex;
    animation: fadeIn 0.5s ease;
}

.start-screen-title {
    font-size: 4rem;
    color: var(--gold);
    text-shadow: 4px 4px 8px rgba(0,0,0,0.5);
    letter-spacing: 10px;
    margin-bottom: 20px;
    animation: titleGlow 2s ease-in-out infinite;
}

@keyframes titleGlow {
    0%, 100% { text-shadow: 4px 4px 8px rgba(0,0,0,0.5), 0 0 20px var(--gold); }
    50% { text-shadow: 4px 4px 8px rgba(0,0,0,0.5), 0 0 40px var(--gold-light); }
}

.start-screen-subtitle {
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 60px;
    letter-spacing: 5px;
}

.start-screen-buttons {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
}

.start-btn {
    padding: 20px 60px;
    font-size: 1.5rem;
    border: 3px solid var(--gold);
    border-radius: 50px;
    background: linear-gradient(to bottom, var(--bg-paper), var(--bg-paper-dark));
    color: var(--china-red-dark);
    font-weight: bold;
    cursor: pointer;
    transition: var(--transition-normal);
    font-family: inherit;
    min-width: 300px;
    box-shadow: var(--shadow-lg);
}

.start-btn:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-xl);
    background: linear-gradient(to bottom, var(--gold-light), var(--gold));
    color: var(--china-red);
}

.start-btn:active {
    transform: translateY(-2px);
}

.start-btn.btn-primary {
    background: linear-gradient(to bottom, var(--china-red-light), var(--china-red));
    color: var(--white);
}

.start-btn.btn-primary:hover {
    background: linear-gradient(to bottom, var(--china-red), var(--china-red-dark));
}

/* 发牌动画 */
@keyframes dealAnimation {
    0% {
        transform: translateY(-200px) rotate(-10deg);
        opacity: 0;
    }
    100% {
        transform: translateY(0) rotate(0);
        opacity: 1;
    }
}

.card-deal-anim {
    animation: dealAnimation 0.4s ease forwards;
}

/* ========================================
   出的牌区域增强样式
   ======================================== */

.played-cards-area {
    display: flex;
    gap: 5px;
    min-height: 80px;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    padding: 10px;
    background: rgba(0,0,0,0.2);
    border-radius: 10px;
    border: 1px solid rgba(212,175,55,0.3);
    min-width: 200px;
}

.played-cards-area .card {
    width: 50px !important;
    height: 70px !important;
    margin-left: -20px;
}

.played-cards-area .card:first-child {
    margin-left: 0;
}

.last-player-indicator {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: var(--china-red-dark);
    padding: 3px 10px;
    border-radius: 10px;
    font-size: 0.75rem;
    font-weight: bold;
    white-space: nowrap;
    animation: bounce 1s ease infinite;
}

@keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-5px); }
}

/* 动画类 */
.card-play {
    animation: playCard 0.5s ease;
}

@keyframes playCard {
    0% {
        transform: translateY(0) scale(1);
        opacity: 1;
    }
    50% {
        transform: translateY(-50px) scale(1.1);
        opacity: 1;
    }
    100% {
        transform: translateY(0) scale(1);
        opacity: 1;
    }
}

.card-deal {
    animation: dealCard 0.3s ease;
}

@keyframes dealCard {
    0% {
        transform: translateX(-100px) rotate(-10deg);
        opacity: 0;
    }
    100% {
        transform: translateX(0) rotate(0);
        opacity: 1;
    }
}

/* 滚动条美化 */
::-webkit-scrollbar {
    width: 8px;
    height: 8px;
}

::-webkit-scrollbar-track {
    background: var(--bg-paper-dark);
    border-radius: 4px;
}

::-webkit-scrollbar-thumb {
    background: var(--gold);
    border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
    background: var(--gold-dark);
}

/* 贡牌界面样式 */
.tribute-content {
    padding: 20px;
    text-align: center;
}

.tribute-message {
    font-size: 1.2rem;
    color: var(--text-primary);
    margin-bottom: 15px;
    font-weight: bold;
}

.tribute-info {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 20px;
    padding: 10px;
    background: var(--bg-paper-dark);
    border-radius: 8px;
}

.tribute-select-section {
    margin-top: 20px;
}

.tribute-instruction {
    font-size: 1rem;
    color: var(--text-primary);
    margin-bottom: 15px;
}

.tribute-cards-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-bottom: 20px;
    min-height: 100px;
    padding: 15px;
    background: var(--bg-paper-dark);
    border-radius: 10px;
}

.tribute-card {
    width: 60px;
    height: 84px;
    background: var(--bg-paper);
    border-radius: 8px;
    border: 2px solid var(--white);
    box-shadow: var(--shadow-md);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition-fast);
    font-size: 1.2rem;
    font-weight: bold;
    user-select: none;
}

.tribute-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--gold);
}

.tribute-card.selected {
    border-color: var(--china-red);
    box-shadow: 0 0 0 3px var(--china-red-light);
    transform: translateY(-5px);
}

.tribute-card.red {
    color: var(--china-red);
}

.tribute-card.black {
    color: var(--text-dark);
}

.tribute-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
}

.resist-section {
    padding: 30px;
}

.resist-message {
    font-size: 1.5rem;
    color: var(--china-red);
    font-weight: bold;
    margin-bottom: 20px;
    animation: pulse 1s infinite;
}

/* ========================================
   贡牌动画样式
   ======================================== */

.tribute-message {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: linear-gradient(135deg, var(--china-red), var(--china-red-dark));
    color: var(--gold);
    padding: 30px 50px;
    border-radius: 15px;
    border: 3px solid var(--gold);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    z-index: 10000;
    font-size: 1.8rem;
    font-weight: bold;
    text-align: center;
    animation: tributeMessageFade 3s ease forwards;
}

@keyframes tributeMessageFade {
    0% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.8);
    }
    20% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
    }
    80% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
    }
    100% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.9);
    }
}

.tribute-card-anim {
    position: fixed;
    z-index: 9999;
    width: 80px;
    height: 112px;
    border-radius: 8px;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.4);
    pointer-events: none;
}

.tribute-card-anim.tribute {
    border: 3px solid var(--gold);
    box-shadow: 0 0 20px rgba(212, 175, 55, 0.8);
}

.tribute-card-anim.return {
    border: 3px solid var(--china-red);
    box-shadow: 0 0 20px rgba(196, 30, 58, 0.8);
}
