<!-- 出牌区组件模板 -->
<view class="play-area-container">
  <!-- 出牌区标题 -->
  <view class="play-area-header" bindtap="toggleExpand">
    <text class="play-area-title">出牌记录</text>
    <text class="play-area-round">第 {{getCurrentRound()}} 轮</text>
    <view class="expand-indicator {{isExpanded ? 'expanded' : ''}}">
      <text>▼</text>
    </view>
  </view>
  
  <!-- 当前出牌区域 -->
  <view class="current-play-area" wx:if="{{currentPlay.length > 0}}">
    <view class="current-play-label">
      <text>当前出牌</text>
    </view>
    <view class="current-play-cards">
      <card
        wx:for="{{currentPlay}}"
        wx:key="*this"
        class="current-play-card"
        suit="{{item.suit}}"
        value="{{item.value}}"
        isSelected="{{false}}"
        isPlayable="{{false}}"
      />
    </view>
  </view>
  
  <!-- 历史记录区域 -->
  <view class="play-history-area" wx:if="{{getVisibleHistory().length > 0}}">
    <view 
      class="play-history-item" 
      wx:for="{{getVisibleHistory()}}" 
      wx:key="round"
    >
      <view class="play-history-header">
        <text class="play-history-round">第 {{item.round}} 轮</text>
        <text class="play-history-player" wx:if="{{showPlayerName}}">{{item.playerName}}</text>
        <text class="play-history-type">{{getPlayTypeName(item.playType)}}</text>
      </view>
      <view class="play-history-cards">
        <card
          wx:for="{{item.cards}}"
          wx:key="*this"
          class="history-card"
          suit="{{item.suit}}"
          value="{{item.value}}"
          isSelected="{{false}}"
          isPlayable="{{false}}"
          cardWidth="60"
          cardHeight="84"
        />
      </view>
    </view>
    
    <!-- 展开更多提示 -->
    <view class="expand-more-hint" wx:if="{{!isExpanded && playHistory.length > maxVisibleRounds}}" bindtap="toggleExpand">
      <text>查看全部 {{playHistory.length}} 轮记录</text>
    </view>
  </view>
  
  <!-- 空状态 -->
  <view class="play-area-empty" wx:if="{{playHistory.length === 0 && currentPlay.length === 0}}">
    <text>等待出牌...</text>
  </view>
</view>
