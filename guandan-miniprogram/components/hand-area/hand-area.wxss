/**
 * 手牌区组件样式
 * 5 行网格布局
 */
.hand-area-container {
  position: relative;
  padding: var(--spacing-md);
  background: rgba(26, 71, 42, 0.3);
  border-radius: var(--radius-lg);
  min-height: 600rpx;
}

/* 网格容器 */
.hand-area-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 每一行 - 修复 BUG-009: 牌间距从 10px 调整为 16px */
.hand-row {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  align-items: center;
  gap: 16px; /* 原 10px → 改为 16px，确保手指触摸不误触 */
  min-height: 110rpx;
}

/* 手牌 */
.hand-card {
  flex-shrink: 0;
  transition: transform 0.2s ease;
}

/* 选中效果增强 */
.hand-card /deep/ .card-container.selected {
  z-index: 10;
}

/* 空手牌提示 */
.hand-area-empty {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.hand-area-empty text {
  font-size: var(--font-size-lg);
  color: var(--gray);
  opacity: 0.6;
}

/* 出牌动画 */
@keyframes cardPlayOut {
  0% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.1);
  }
  100% {
    opacity: 0;
    transform: scale(0.8) translateY(-100rpx);
  }
}

.hand-card.playing-out {
  animation: cardPlayOut 0.3s ease forwards;
}

/* 收牌动画 */
@keyframes cardDealIn {
  0% {
    opacity: 0;
    transform: scale(0.8) translateY(100rpx);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.hand-card.deal-in {
  animation: cardDealIn 0.3s ease forwards;
}

/* 响应式调整 - 修复 BUG-009: 小屏设备最小间距 12px */
@media (max-width: 750rpx) {
  .hand-row {
    gap: 12px; /* 小屏设备最小 12px，原 6px */
  }
  
  .hand-card {
    transform: scale(0.9);
  }
}

/* 超小屏设备（iPhone SE 等） - 修复 BUG-009 */
@media (max-width: 375px) {
  .hand-row {
    gap: 12px; /* 最小 12px */
  }
  
  .hand-card {
    transform: scale(0.85);
  }
}

/* 提示可出牌 */
.hand-card.playable /deep/ .card-container {
  box-shadow: 0 0 16rpx rgba(52, 199, 89, 0.3);
}

/* 批量操作模式 */
.hand-area-container.batch-mode .hand-card {
  border: 2rpx solid var(--active-green);
}
