/**
 * 卡牌组件样式
 */
.card-container {
  position: relative;
  background: var(--white);
  border-radius: 12rpx;
  overflow: hidden;
  transition: all 0.2s ease;
  cursor: pointer;
  user-select: none;
}

.card-container.selected {
  transform: translateY(-20rpx);
  box-shadow: 0 -8rpx 16rpx rgba(0, 0, 0, 0.3);
}

.card-container.disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #ffffff 0%, #f8f8f8 100%);
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
}

.card-content {
  position: relative;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 左上角：字 + 花竖排 */
.card-corner-top-left {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-value {
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1;
  color: var(--dark-gray);
}

.card-suit {
  font-size: 28rpx;
  line-height: 1;
  margin-top: 4rpx;
}

/* 中间：花色偏右下 */
.card-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(20%, 10%);
}

.card-suit-large {
  font-size: 80rpx;
  line-height: 1;
  opacity: 0.9;
}

/* 王牌样式 */
.card-content.joker {
  display: flex;
  justify-content: center;
  align-items: center;
}

.card-value-joker {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--dark-gray);
}

/* 选牌动画 */
@keyframes cardSelect {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
  100% {
    transform: translateY(-20rpx);
  }
}

.card-container.selected {
  animation: cardSelect 0.2s ease forwards;
}

/* 出牌动画 */
@keyframes cardPlay {
  0% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-200rpx) scale(0.8);
  }
}

.card-container.playing {
  animation: cardPlay 0.3s ease forwards;
}
